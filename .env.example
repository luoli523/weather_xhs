# OpenWeatherMap API Key
# 申请地址: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=put_your_api_key_here

# Telegram Bot 推送配置（可选）
# TELEGRAM_ENABLED=true 启用推送，其他值或不设置则跳过
# 1. 与 @BotFather 对话创建 Bot，获取 Token
# 2. 与 Bot 发送一条消息，然后访问 https://api.telegram.org/bot<TOKEN>/getUpdates 获取 chat_id
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 小红书自动发布配置（可选）
# XHS_ENABLED=true 启用发布，其他值或不设置则跳过
# 首次使用需先运行 python scripts/xhs_login.py 完成登录
# XHS_STORAGE_STATE_PATH 可选，默认 ~/.xhs/storage_state.json
XHS_ENABLED=false
XHS_STORAGE_STATE_PATH=

# Instagram 自动发布配置（可选）
# IG_ENABLED=true 启用发布，其他值或不设置则跳过
# 首次使用需先运行 python scripts/ig_login.py 完成登录
# IG_SESSION_PATH 可选，默认 ~/.instagram/session.json
IG_ENABLED=false
IG_USERNAME=
IG_PASSWORD=
IG_SESSION_PATH=

# OpenAI API（诗词模块，可选）
# OPENAI_API_KEY 配置后自动启用每日诗词模块
# 使用 gpt-4o-mini，每天约 $0.001
OPENAI_API_KEY=
