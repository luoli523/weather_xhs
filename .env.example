# OpenWeatherMap API Key
# 申请地址: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=put_your_api_key_here

# Telegram Bot 推送配置（可选）
# TELEGRAM_ENABLED=true 启用推送，其他值或不设置则跳过
# 1. 与 @BotFather 对话创建 Bot，获取 Token
# 2. 与 Bot 发送一条消息，然后访问 https://api.telegram.org/bot<TOKEN>/getUpdates 获取 chat_id
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
